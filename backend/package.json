{
  "name": "primetrade-backend",
  "version": "1.0.0",
  "description": "Scalable REST API with JWT Authentication & Role-Based Access Control",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
