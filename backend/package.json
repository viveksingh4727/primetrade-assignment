{
  "name": "primetrade-backend",
  "version": "1.0.0",
  "description": "Scalable REST API with JWT Authentication & Role-Based Access Control",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node --experimental-strip-types server.js",
    "dev": "nodemon --exec 'node --experimental-strip-types' server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:studio": "prisma studio",
    "prisma:seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "joi": "^17.13.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.3",
    "prisma": "^7.0.0"
  }
}
